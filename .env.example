# Copy to .env for local development. Never commit .env.
ORBI_ENVIRONMENT=development
ORBI_LOG_LEVEL=INFO
ORBI_HOST_UID=1000
ORBI_HOST_GID=1000
ORBI_POSTGRES_PASSWORD=replace-with-random-database-password
ORBI_POSTGRES_HOST_PORT=55432
ORBI_DATABASE_URL=postgresql+asyncpg://orbi:change-me@postgres:5432/orbi
ORBI_REDIS_URL=redis://redis:6379/0
ORBI_REDIS_HOST_PORT=56379

# Generate at least 32 random bytes. Do not reuse between environments.
ORBI_API_KEY_PEPPER=replace-with-long-random-value
ORBI_WORKER_ENROLLMENT_PEPPER=replace-with-different-long-random-value

# Store private keys as mounted files, not multiline environment variables.
ORBI_JWT_PRIVATE_KEY_PATH=/run/secrets/orbi_jwt_private.pem
ORBI_JWT_PUBLIC_KEY_PATH=/run/secrets/orbi_jwt_public.pem
ORBI_JWT_ISSUER=orbi-core
ORBI_JWT_AUDIENCE=orbi-worker
ORBI_WORKER_TOKEN_TTL_SECONDS=3600

# Argon2id hash of the admin bootstrap token. Never store the raw token here.
ORBI_ADMIN_TOKEN_HASH=replace-with-argon2id-hash
ORBI_ADMIN_TOKEN_PEPPER=replace-with-long-random-value

ORBI_RATE_LIMIT_RPM_DEFAULT=60
ORBI_MAX_REQUEST_BODY_BYTES=1048576
ORBI_REQUEST_WAIT_TIMEOUT_SECONDS=60
ORBI_WORKER_LEASE_SECONDS=120
ORBI_LEASE_RECOVERY_INTERVAL_SECONDS=30
ORBI_CIRCUIT_FAILURE_THRESHOLD=5
ORBI_CIRCUIT_COOLDOWN_SECONDS=120

# ORBI Node receives only gateway connectivity and one-time enrollment credentials.
# After `orbi_node_v1_`, take exactly 12 characters as the ID and the final 43 as the secret.
ORBI_NODE_CORE_URL=http://gateway:8000
ORBI_NODE_NAME=local-docker-node
ORBI_NODE_PROVIDER_TYPE=docker
ORBI_NODE_ENROLLMENT_ID=replace-with-id
ORBI_NODE_ENROLLMENT_SECRET=replace-with-one-time-secret
ORBI_NODE_SUPPORTED_MODELS=test/model
ORBI_NODE_HEARTBEAT_INTERVAL_SECONDS=30
ORBI_NODE_POLL_INTERVAL_SECONDS=1
ORBI_NODE_HTTP_TIMEOUT_SECONDS=10
ORBI_NODE_LOG_LEVEL=INFO
